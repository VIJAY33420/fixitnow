{
  "name": "fixitnow-root",
  "version": "1.0.0",
  "description": "Root configuration for FixItNow Monorepo",
  "scripts": {
    "frontend": "npm run dev --prefix Frontend",
    "backend": "npm run dev --prefix Backend",
    "dev": "npm run frontend & npm run backend",
    "build": "npm run build --prefix Frontend",
    "seed": "node Backend/scripts/seed.js",
    "install-all": "npm install --prefix Frontend && npm install --prefix Backend"
  },
  "workspaces": [
    "Frontend",
    "Backend"
  ]
}
